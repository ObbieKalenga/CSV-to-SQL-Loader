# Copy this file to ".env" and fill in your own values.
# .env is git-ignored so your credentials never get committed.
#
# The notebook uses a hardcoded connection string for simplicity. These values
# are here as a reference for the settings you need to update in the
# "CONNECT TO SQL SERVER" cell (server, database, driver).

DB_SERVER=localhost\SQLEXPRESS
DB_NAME=CSV_Loader_Demo

# Leave DB_USER / DB_PASSWORD blank to use Windows (trusted) authentication.
DB_USER=
DB_PASSWORD=

DB_DRIVER=ODBC Driver 17 for SQL Server
